{
  "name": "jic-wagtail-cms",
  "version": "1.0.0",
  "description": "JIC Website - Wagtail CMS with TailwindCSS and Flowbite",
  "main": "index.js",
  "scripts": {
    "tailwind:watch": "npx tailwindcss -i ./mysite/theme/static/src/input.css -o ./mysite/theme/static/src/output.css --watch",
    "tailwind:build": "npx tailwindcss -i ./mysite/theme/static/src/input.css -o ./mysite/theme/static/src/output.css --minify"
  },
  "keywords": [
    "wagtail",
    "tailwindcss",
    "flowbite",
    "docker",
    "minio"
  ],
  "author": "JIC Development Team",
  "license": "ISC",
  "dependencies": {
    "tailwindcss": "^3.4.1",
    "flowbite": "^2.2.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/forms": "^0.5.7"
  }
}
