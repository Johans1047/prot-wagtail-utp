# ==============================================================================
# CONFIGURACIÓN DE ENTORNO - JIC WAGTAIL CMS
# ==============================================================================
# Copia este archivo a .env y configura los valores según tu entorno
# ==============================================================================

# Django Configuration
DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://jicuser:jicpass@db:5432/jic_db
DB_NAME=jic_db
DB_USER=jicuser
DB_PASSWORD=jicpass
DB_HOST=db
DB_PORT=5432

# MinIO Object Storage Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=jic-media
MINIO_EXTERNAL_ENDPOINT=localhost:9000  # Para acceso externo

# Application
PYTHONUNBUFFERED=1
SITE_NAME=JIC Website
SITE_DOMAIN=localhost:8000

# Email Configuration (Opcional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-password

# Security (Producción)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
